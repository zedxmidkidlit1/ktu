---
interface Props {
  title: string;
  summary: string;
  meta?: string;
  href?: string;
  badge?: string;
}

const { title, summary, meta, href, badge } = Astro.props;
const Tag = href ? "a" : "article";
---

<Tag
  href={href}
  class="glass-panel block h-full p-5 transition-colors duration-200 hover:bg-[var(--surface-strong)]"
>
  {badge && <p class="kicker">{badge}</p>}
  <h3 class="mt-2 font-display text-2xl font-semibold leading-[1.14] tracking-[-0.015em] text-[var(--ink)]">{title}</h3>
  <p class="mt-2 text-[var(--muted)]">{summary}</p>
  {meta && <p class="mt-4 text-sm font-semibold text-[var(--brand-hover)]">{meta}</p>}
</Tag>
