---
interface Props {
  title: string;
  summary: string;
  meta?: string;
  href?: string;
  badge?: string;
}

const { title, summary, meta, href, badge } = Astro.props;
const Tag = href ? "a" : "article";
---

<Tag
  href={href}
  class="glass-panel block h-full p-5 no-underline transition-transform duration-200 hover:-translate-y-0.5 hover:border-[var(--line-strong)]"
>
  {badge && <p class="kicker">{badge}</p>}
  <h3 class="mt-2 font-display text-[1.42rem] font-bold leading-[1.14] tracking-[-0.02em] text-[var(--ink)]">{title}</h3>
  <p class="mt-2 text-[0.96rem] text-[var(--muted)]">{summary}</p>
  {meta && <p class="mt-4 text-sm font-semibold text-[var(--brand)]">{meta}</p>}
</Tag>
