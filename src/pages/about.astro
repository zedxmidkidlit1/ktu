---
export const prerender = true;

import SiteLayout from "../layouts/SiteLayout.astro";
---

<SiteLayout title="About KTU" description="Vision, mission, and institutional profile of Kyaukse Technological University.">
  <div class="shell">
    <section class="glass-panel p-6 md:p-8">
      <p class="kicker">About Us</p>
      <h1 class="section-title">Kyaukse Technological University</h1>
      <p class="section-subtitle">
        Technological University (Kyaukse) is a government-funded institution committed to engineering and science education
        in Myanmar.
      </p>

      <div class="mt-6 grid gap-4 md:grid-cols-3">
        <article class="rounded-xl border border-[var(--line)] bg-[var(--surface-soft)] p-4">
          <h2 class="font-display text-2xl font-bold">Mission</h2>
          <p class="mt-2 text-[var(--muted)]">
            Serve Myanmar through quality engineering education, innovative research, and dedicated service to society.
          </p>
        </article>
        <article class="rounded-xl border border-[var(--line)] bg-[var(--surface-soft)] p-4">
          <h2 class="font-display text-2xl font-bold">Vision</h2>
          <p class="mt-2 text-[var(--muted)]">
            Contribute to Myanmar and the global community through innovation and ethical leadership.
          </p>
        </article>
        <article class="rounded-xl border border-[var(--line)] bg-[var(--surface-soft)] p-4">
          <h2 class="font-display text-2xl font-bold">Accreditation</h2>
          <p class="mt-2 text-[var(--muted)]">
            KTU has obtained Myanmar Engineering Council (MEC) accreditation for quality engineering programs.
          </p>
        </article>
      </div>
    </section>
  </div>
</SiteLayout>
