---
export const prerender = true;

import SiteLayout from "../../layouts/SiteLayout.astro";
import { listPrograms } from "../../lib/cms/content";
import { formatDate, formatUSD } from "../../lib/format";
import type { ProgramItem } from "../../lib/cms/types";

interface Props {
  program: ProgramItem;
}

export async function getStaticPaths() {
  const programs = await listPrograms();
  return programs.map((program) => ({
    params: { slug: program.slug },
    props: { program },
  }));
}

const { program } = Astro.props;
---

<SiteLayout title={`${program.title} | Northfield MU`} description={program.summary}>
  <div class="shell">
    <article class="glass-panel p-6 md:p-8">
      <a href="/programs" class="text-sm font-semibold text-[var(--brand)] hover:text-[var(--brand-deep)]">
        ← Back to programs
      </a>
      <p class="kicker mt-4">{program.department}</p>
      <h1 class="section-title mt-2">{program.title}</h1>
      <p class="section-subtitle">{program.summary}</p>

      <div class="mt-6 grid gap-3 md:grid-cols-2 lg:grid-cols-4">
        <div class="rounded-xl border border-[var(--line)] bg-[var(--surface-soft)] p-4">
          <p class="text-xs text-[var(--muted)]">Degree</p>
          <p class="font-semibold">{program.degree}</p>
        </div>
        <div class="rounded-xl border border-[var(--line)] bg-[var(--surface-soft)] p-4">
          <p class="text-xs text-[var(--muted)]">Duration</p>
          <p class="font-semibold">{program.duration}</p>
        </div>
        <div class="rounded-xl border border-[var(--line)] bg-[var(--surface-soft)] p-4">
          <p class="text-xs text-[var(--muted)]">Campus</p>
          <p class="font-semibold">{program.campus}</p>
        </div>
        <div class="rounded-xl border border-[var(--line)] bg-[var(--surface-soft)] p-4">
          <p class="text-xs text-[var(--muted)]">Tuition / Year</p>
          <p class="font-semibold">{formatUSD(program.tuitionPerYearUSD)}</p>
        </div>
      </div>

      <div class="mt-6 grid gap-5 lg:grid-cols-[1fr_320px]">
        <section class="rounded-xl border border-[var(--line)] bg-[var(--surface-soft)] p-5">
          <h2 class="font-display text-2xl font-bold">Program Overview</h2>
          <p class="mt-3 text-[var(--muted)]">{program.description}</p>
          {program.content && <p class="mt-3 text-[var(--muted)]">{program.content}</p>}
          <ul class="mt-4 flex flex-wrap gap-2">
            {
              program.tags.map((tag) => (
                <li class="rounded-full border border-[var(--line)] bg-[var(--surface-strong)] px-3 py-1 text-xs font-semibold">
                  {tag}
                </li>
              ))
            }
          </ul>
        </section>

        <aside class="rounded-xl border border-[var(--line)] bg-[var(--surface-soft)] p-5">
          <h2 class="font-display text-2xl font-bold">Apply</h2>
          <p class="mt-2 text-sm text-[var(--muted)]">
            Priority application deadline: <strong>{formatDate(program.applicationDeadline)}</strong>
          </p>
          <a href="/admissions" class="btn-primary mt-4 w-full">
            Start Application
          </a>
          <a href="/contact" class="btn-secondary mt-2 w-full">
            Talk to Advisor
          </a>
        </aside>
      </div>
    </article>
  </div>
</SiteLayout>
