---
export const prerender = true;

import InfoCard from "../../components/InfoCard.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import SiteLayout from "../../layouts/SiteLayout.astro";
import { listPrograms } from "../../lib/cms/content";
import { formatDate } from "../../lib/format";

const programs = await listPrograms();
---

<SiteLayout
  title="Departments | Kyaukse Technological University"
  description="Engineering and science departments at KTU."
>
  <div class="shell">
    <section class="glass-panel p-6 md:p-8">
      <SectionHeading
        eyebrow="Academic Departments"
        title="Departments at Technological University Kyaukse"
        subtitle="Explore engineering and science-focused departments and admissions status."
      />
      <div class="mt-6 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
        {
          programs.map((program) => (
            <InfoCard
              title={program.title}
              summary={program.summary}
              badge={program.department}
              meta={program.applicationDeadline
                ? `Application window · ${formatDate(program.applicationDeadline)}`
                : "Admissions open for 2025-2026 academic year"}
              href={`/programs/${program.slug}`}
            />
          ))
        }
      </div>
    </section>
  </div>
</SiteLayout>
