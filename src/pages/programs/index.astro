---
export const prerender = true;

import InfoCard from "../../components/InfoCard.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import SiteLayout from "../../layouts/SiteLayout.astro";
import { listPrograms } from "../../lib/cms/content";
import { formatDate, formatUSD } from "../../lib/format";

const programs = await listPrograms();
---

<SiteLayout
  title="Programs | Northfield Modern University"
  description="Degree programs with tuition, deadlines, and department details."
>
  <div class="shell">
    <section class="glass-panel p-6 md:p-8">
      <SectionHeading
        eyebrow="Academic Programs"
        title="Career-ready degree tracks"
        subtitle="Compare program focus, admissions deadlines, and yearly tuition in one place."
      />
      <div class="mt-6 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
        {
          programs.map((program) => (
            <InfoCard
              title={program.title}
              summary={program.summary}
              badge={program.department}
              meta={`${formatDate(program.applicationDeadline)} deadline · ${formatUSD(program.tuitionPerYearUSD)}/year`}
              href={`/programs/${program.slug}`}
            />
          ))
        }
      </div>
    </section>
  </div>
</SiteLayout>
