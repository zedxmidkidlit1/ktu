---
export const prerender = true;

import InfoCard from "../components/InfoCard.astro";
import SectionHeading from "../components/SectionHeading.astro";
import SiteLayout from "../layouts/SiteLayout.astro";
import { formatDate, formatDateTime, formatUSD } from "../lib/format";
import { listEvents, listNews, listPrograms } from "../lib/cms/content";

const [programs, news, events] = await Promise.all([listPrograms(), listNews(), listEvents()]);
const featuredPrograms = programs.slice(0, 3);
const featuredNews = news.slice(0, 2);
const upcomingEvents = events.slice(0, 2);
---

<SiteLayout
  title="Northfield Modern University | Admissions, Programs, Events"
  description="Explore programs, admissions timelines, scholarship guidance, and campus events."
>
  <div class="shell">
    <section class="glass-panel overflow-hidden p-6 md:p-10">
      <div class="grid items-start gap-8 md:grid-cols-[1.1fr_0.9fr]">
        <div>
          <p class="kicker stagger-rise">Enrollment Open: Fall 2026 Intake</p>
          <h1 class="section-title stagger-rise delay-1 text-4xl md:text-6xl">
            Design-led university website with Apple-style clarity.
          </h1>
          <p class="section-subtitle stagger-rise delay-2">
            Structured information, cinematic spacing, and direct calls-to-action for admissions, academics, and events.
          </p>
          <div class="mt-6 flex flex-wrap gap-3 stagger-rise delay-3">
            <a href="/admissions" class="btn-primary">Start Application</a>
            <a href="/programs" class="btn-secondary">Learn More</a>
          </div>
        </div>

        <aside class="rounded-xl border border-[var(--line)] bg-[var(--surface-strong)] p-4 md:p-5">
          <p class="kicker">At a Glance</p>
          <dl class="mt-3 grid grid-cols-2 gap-3">
            <div class="rounded-xl border border-[var(--line)] bg-[var(--surface-soft)] p-3">
              <dt class="text-xs text-[var(--muted)]">Programs</dt>
              <dd class="font-display text-2xl font-semibold">27</dd>
            </div>
            <div class="rounded-xl border border-[var(--line)] bg-[var(--surface-soft)] p-3">
              <dt class="text-xs text-[var(--muted)]">Avg Class Size</dt>
              <dd class="font-display text-2xl font-semibold">24</dd>
            </div>
            <div class="rounded-xl border border-[var(--line)] bg-[var(--surface-soft)] p-3">
              <dt class="text-xs text-[var(--muted)]">Scholarship Aid</dt>
              <dd class="font-display text-2xl font-semibold">$8.2M</dd>
            </div>
            <div class="rounded-xl border border-[var(--line)] bg-[var(--surface-soft)] p-3">
              <dt class="text-xs text-[var(--muted)]">Career Placement</dt>
              <dd class="font-display text-2xl font-semibold">93%</dd>
            </div>
          </dl>
        </aside>
      </div>
    </section>

    <section class="mt-10">
      <SectionHeading
        eyebrow="Featured Programs"
        title="Find the degree path that fits your goals"
        subtitle="Explore high-impact programs with clear deadlines, transparent tuition, and applied learning."
      />
      <div class="mt-5 grid gap-4 md:grid-cols-3">
        {
          featuredPrograms.map((program) => (
            <InfoCard
              title={program.title}
              summary={program.summary}
              badge={program.department}
              meta={`${program.degree} · ${program.duration} · ${formatUSD(program.tuitionPerYearUSD)}/year`}
              href={`/programs/${program.slug}`}
            />
          ))
        }
      </div>
    </section>

    <section class="mt-10 grid gap-4 md:grid-cols-2">
      <div class="glass-panel p-5">
        <SectionHeading
          eyebrow="Latest News"
          title="Campus updates and key announcements"
          subtitle="Official announcements from admissions, research, and student life."
        />
        <div class="mt-4 space-y-3">
          {
            featuredNews.map((item) => (
              <a
                href={`/news/${item.slug}`}
                class="block rounded-xl border border-[var(--line)] bg-[var(--surface-soft)] p-4 hover:bg-[var(--surface-strong)]"
              >
                <p class="kicker">{item.category}</p>
                <h3 class="mt-1 font-display text-2xl font-semibold leading-tight">{item.title}</h3>
                <p class="mt-2 text-sm text-[var(--muted)]">{item.summary}</p>
                <p class="mt-2 text-xs font-semibold text-[var(--brand-hover)]">
                  {formatDate(item.publishedAt)} · {item.author}
                </p>
              </a>
            ))
          }
        </div>
      </div>

      <div class="glass-panel p-5">
        <SectionHeading
          eyebrow="Upcoming Events"
          title="Visit, learn, and connect"
          subtitle="Open days, webinars, and workshops for future students and families."
        />
        <div class="mt-4 space-y-3">
          {
            upcomingEvents.map((item) => (
              <a
                href={`/events/${item.slug}`}
                class="block rounded-xl border border-[var(--line)] bg-[var(--surface-soft)] p-4 hover:bg-[var(--surface-strong)]"
              >
                <p class="kicker">{item.eventType}</p>
                <h3 class="mt-1 font-display text-2xl font-semibold leading-tight">{item.title}</h3>
                <p class="mt-2 text-sm text-[var(--muted)]">{item.summary}</p>
                <p class="mt-2 text-xs font-semibold text-[var(--brand-hover)]">
                  {formatDateTime(item.startAt)} · {item.location}
                </p>
              </a>
            ))
          }
        </div>
      </div>
    </section>
  </div>
</SiteLayout>
