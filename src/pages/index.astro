---
export const prerender = true;

import InfoCard from "../components/InfoCard.astro";
import SectionHeading from "../components/SectionHeading.astro";
import SiteLayout from "../layouts/SiteLayout.astro";
import { formatDate, formatDateTime } from "../lib/format";
import { listEvents, listNews, listPrograms } from "../lib/cms/content";

const [programs, news, events] = await Promise.all([listPrograms(), listNews(), listEvents()]);
const featuredPrograms = programs.slice(0, 3);
const featuredNews = news.slice(0, 2);
const upcomingEvents = events.slice(0, 2);
---

<SiteLayout
  title="Kyaukse Technological University | Admissions, Departments, Events"
  description="Official website of Kyaukse Technological University (KTU), Myanmar."
>
  <div class="shell">
    <section class="glass-panel overflow-hidden p-5 sm:p-7 lg:p-10">
      <div class="grid items-start gap-6 lg:grid-cols-[1.16fr_0.84fr] lg:gap-8">
        <div>
          <p class="kicker stagger-rise">Official Website · Technological University Kyaukse</p>
          <h1 class="section-title stagger-rise delay-1 text-[clamp(2.05rem,5.8vw,4.15rem)]">
            Engineering education for Myanmar's future.
          </h1>
          <p class="section-subtitle stagger-rise delay-2">
            Government-funded institution offering Bachelor and Master programs in Engineering and Science with a focus on
            quality education, research, and community impact.
          </p>
          <div class="mt-6 flex flex-wrap gap-2.5 stagger-rise delay-3">
            <a href="/admissions" class="btn-primary">Start Application</a>
            <a href="/programs" class="btn-secondary">View Departments</a>
          </div>
        </div>

        <aside class="rounded-2xl border border-[var(--line)] bg-[var(--surface-soft)] p-4 sm:p-5">
          <p class="kicker">At a Glance</p>
          <dl class="mt-3 grid grid-cols-2 gap-3">
            <div class="rounded-xl border border-[var(--line)] bg-[var(--surface)] p-3">
              <dt class="text-xs text-[var(--muted)]">Departments</dt>
              <dd class="font-display text-2xl font-bold text-[var(--ink)]">15</dd>
            </div>
            <div class="rounded-xl border border-[var(--line)] bg-[var(--surface)] p-3">
              <dt class="text-xs text-[var(--muted)]">Institution Type</dt>
              <dd class="font-display text-2xl font-bold text-[var(--ink)]">Public</dd>
            </div>
            <div class="rounded-xl border border-[var(--line)] bg-[var(--surface)] p-3">
              <dt class="text-xs text-[var(--muted)]">Accreditation</dt>
              <dd class="font-display text-2xl font-bold text-[var(--ink)]">MEC</dd>
            </div>
            <div class="rounded-xl border border-[var(--line)] bg-[var(--surface)] p-3">
              <dt class="text-xs text-[var(--muted)]">Region</dt>
              <dd class="font-display text-2xl font-bold text-[var(--ink)]">Mandalay</dd>
            </div>
          </dl>
        </aside>
      </div>
    </section>

    <section class="mt-9 sm:mt-10">
      <SectionHeading
        eyebrow="Featured Departments"
        title="Explore key engineering disciplines at KTU"
        subtitle="Departments aligned with national development priorities and modern engineering practice."
      />
      <div class="mt-5 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
        {
          featuredPrograms.map((program) => (
            <InfoCard
              title={program.title}
              summary={program.summary}
              badge={program.department}
              meta={program.applicationDeadline
                ? `${program.degree} · ${program.duration} · Apply by ${formatDate(program.applicationDeadline)}`
                : `${program.degree} · ${program.duration} · Admissions open for 2025-2026`}
              href={`/programs/${program.slug}`}
            />
          ))
        }
      </div>
    </section>

    <section class="mt-9 grid gap-4 lg:mt-10 lg:grid-cols-2">
      <div class="glass-panel p-5 sm:p-6">
        <SectionHeading
          eyebrow="Latest News"
          title="Official announcements and university updates"
          subtitle="Admissions, accreditation, research milestones, and student achievements."
        />
        <div class="mt-4 space-y-3">
          {
            featuredNews.map((item) => (
              <a
                href={`/news/${item.slug}`}
                class="block rounded-xl border border-[var(--line)] bg-[var(--surface-soft)] p-4 no-underline transition-colors hover:border-[var(--line-strong)]"
              >
                <p class="kicker">{item.category}</p>
                <h3 class="mt-1 font-display text-[1.42rem] font-bold leading-tight text-[var(--ink)]">{item.title}</h3>
                <p class="mt-2 text-sm text-[var(--muted)]">{item.summary}</p>
                <p class="mt-2 text-xs font-semibold text-[var(--brand)]">
                  {formatDate(item.publishedAt)} · {item.author}
                </p>
              </a>
            ))
          }
        </div>
      </div>

      <div class="glass-panel p-5 sm:p-6">
        <SectionHeading
          eyebrow="Upcoming Events"
          title="Events, ceremonies, and exhibitions"
          subtitle="Track academic milestones and university-wide activities."
        />
        <div class="mt-4 space-y-3">
          {
            upcomingEvents.map((item) => (
              <a
                href={`/events/${item.slug}`}
                class="block rounded-xl border border-[var(--line)] bg-[var(--surface-soft)] p-4 no-underline transition-colors hover:border-[var(--line-strong)]"
              >
                <p class="kicker">{item.eventType}</p>
                <h3 class="mt-1 font-display text-[1.42rem] font-bold leading-tight text-[var(--ink)]">{item.title}</h3>
                <p class="mt-2 text-sm text-[var(--muted)]">{item.summary}</p>
                <p class="mt-2 text-xs font-semibold text-[var(--brand)]">
                  {item.startAt ? formatDateTime(item.startAt) : "Date to be announced"} · {item.location}
                </p>
              </a>
            ))
          }
        </div>
      </div>
    </section>
  </div>
</SiteLayout>
