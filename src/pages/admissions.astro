---
export const prerender = true;

import SiteLayout from "../layouts/SiteLayout.astro";
---

<SiteLayout
  title="Admissions | Kyaukse Technological University"
  description="Admissions process and application updates for KTU academic programs."
>
  <div class="shell">
    <section class="glass-panel p-6 md:p-8">
      <p class="kicker">Admissions</p>
      <h1 class="section-title">Admission applications for 2025-2026 are open</h1>
      <p class="section-subtitle">
        Technological University Kyaukse welcomes applicants for engineering and science departments.
      </p>

      <ol class="mt-6 space-y-3">
        <li class="rounded-xl border border-[var(--line)] bg-[var(--surface-soft)] p-4">
          <p class="text-sm font-bold text-[var(--brand)]">Step 1 · Choose Department</p>
          <p class="mt-1 text-[var(--muted)]">
            Review available departments and select the field aligned with your academic background.
          </p>
        </li>
        <li class="rounded-xl border border-[var(--line)] bg-[var(--surface-soft)] p-4">
          <p class="text-sm font-bold text-[var(--brand)]">Step 2 · Documents</p>
          <p class="mt-1 text-[var(--muted)]">
            Submit required academic transcripts and application documents through the admissions office.
          </p>
        </li>
        <li class="rounded-xl border border-[var(--line)] bg-[var(--surface-soft)] p-4">
          <p class="text-sm font-bold text-[var(--brand)]">Step 3 · Admission Decision</p>
          <p class="mt-1 text-[var(--muted)]">
            Track official announcements for admission outcomes and enrollment instructions.
          </p>
        </li>
      </ol>

      <div class="mt-6 rounded-xl border border-[var(--line)] bg-[var(--surface-soft)] p-4">
        <p class="text-sm font-bold text-[var(--ink)]">Current Updates</p>
        <ul class="mt-2 space-y-1 text-[var(--muted)]">
          <li>Admission applications for 2025-2026 academic year are now open.</li>
          <li>Final examination schedules are published on the academic calendar channel.</li>
          <li>For exact deadlines, contact the admissions office directly.</li>
        </ul>
      </div>

      <div class="mt-6 flex flex-wrap gap-3">
        <a href="/contact" class="btn-primary">Talk to Admissions</a>
        <a href="/programs" class="btn-secondary">Browse Departments</a>
      </div>
    </section>
  </div>
</SiteLayout>
