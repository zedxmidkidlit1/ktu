---
export const prerender = true;

import SiteLayout from "../layouts/SiteLayout.astro";
---

<SiteLayout
  title="Admissions | Northfield Modern University"
  description="Application process, deadlines, scholarship guidance, and required documents."
>
  <div class="shell">
    <section class="glass-panel p-6 md:p-8">
      <p class="kicker">Admissions</p>
      <h1 class="section-title">How to apply for Fall 2026 intake</h1>
      <p class="section-subtitle">
        Northfield admissions is holistic and deadline-driven. Submit early for scholarship priority.
      </p>

      <ol class="mt-6 space-y-3">
        <li class="rounded-xl border border-[var(--line)] bg-[var(--surface-soft)] p-4">
          <p class="text-sm font-bold text-[var(--brand)]">Step 1 · Application Profile</p>
          <p class="mt-1 text-[var(--muted)]">
            Complete your online profile with personal details, intended major, and academic history.
          </p>
        </li>
        <li class="rounded-xl border border-[var(--line)] bg-[var(--surface-soft)] p-4">
          <p class="text-sm font-bold text-[var(--brand)]">Step 2 · Documents</p>
          <p class="mt-1 text-[var(--muted)]">
            Upload transcript, recommendation letters, personal statement, and portfolio (if required).
          </p>
        </li>
        <li class="rounded-xl border border-[var(--line)] bg-[var(--surface-soft)] p-4">
          <p class="text-sm font-bold text-[var(--brand)]">Step 3 · Scholarship Review</p>
          <p class="mt-1 text-[var(--muted)]">
            Merit and need-based scholarship reviews begin after all required documents are complete.
          </p>
        </li>
      </ol>

      <div class="mt-6 rounded-xl border border-[var(--line)] bg-[var(--surface-soft)] p-4">
        <p class="text-sm font-bold text-[var(--ink)]">Key Dates (Fall 2026)</p>
        <ul class="mt-2 space-y-1 text-[var(--muted)]">
          <li>Early Decision Deadline: November 15, 2025</li>
          <li>Regular Decision Deadline: January 20, 2026</li>
          <li>Scholarship Priority Review: February 10, 2026</li>
        </ul>
      </div>

      <div class="mt-6 flex flex-wrap gap-3">
        <a href="/contact" class="btn-primary">Talk to Admissions</a>
        <a href="/programs" class="btn-secondary">Compare Programs</a>
      </div>
    </section>
  </div>
</SiteLayout>
