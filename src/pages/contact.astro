---
export const prerender = true;

import SiteLayout from "../layouts/SiteLayout.astro";
---

<SiteLayout title="Contact | Northfield MU" description="Connect with admissions, departments, and student support.">
  <div class="shell">
    <section class="glass-panel p-6 md:p-8">
      <p class="kicker">Contact</p>
      <h1 class="section-title">Get in touch with Northfield</h1>
      <p class="section-subtitle">
        For application support, program fit questions, and international admissions guidance.
      </p>

      <div class="mt-6 grid gap-5 md:grid-cols-[1.1fr_0.9fr]">
        <form class="rounded-xl border border-[var(--line)] bg-[var(--surface-soft)] p-5">
          <label class="mb-1 block text-sm font-semibold text-[var(--ink)]" for="name">Full name</label>
          <input
            id="name"
            type="text"
            class="w-full rounded-lg border border-[var(--line)] px-3 py-2 outline-none focus:border-[var(--brand)]"
          />

          <label class="mb-1 mt-4 block text-sm font-semibold text-[var(--ink)]" for="email">Email</label>
          <input
            id="email"
            type="email"
            class="w-full rounded-lg border border-[var(--line)] px-3 py-2 outline-none focus:border-[var(--brand)]"
          />

          <label class="mb-1 mt-4 block text-sm font-semibold text-[var(--ink)]" for="message">Message</label>
          <textarea
            id="message"
            rows="5"
            class="w-full rounded-lg border border-[var(--line)] px-3 py-2 outline-none focus:border-[var(--brand)]"
          ></textarea>

          <button type="button" class="btn-primary mt-4">
            Submit Inquiry
          </button>
          <p class="mt-2 text-xs text-[var(--muted)]">
            This starter form is UI-only. Connect your preferred form backend in production.
          </p>
        </form>

        <aside class="rounded-xl border border-[var(--line)] bg-[var(--surface-soft)] p-5">
          <h2 class="font-display text-2xl font-bold">Direct Channels</h2>
          <ul class="mt-3 space-y-2 text-[var(--muted)]">
            <li><strong class="text-[var(--ink)]">Admissions:</strong> admissions@northfield.edu</li>
            <li><strong class="text-[var(--ink)]">International:</strong> global@northfield.edu</li>
            <li><strong class="text-[var(--ink)]">Phone:</strong> +1 (617) 555-2036</li>
            <li><strong class="text-[var(--ink)]">Hours:</strong> Monday to Friday, 9:00 AM to 5:00 PM EST</li>
          </ul>
        </aside>
      </div>
    </section>
  </div>
</SiteLayout>
